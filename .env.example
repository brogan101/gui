# ─────────────────────────────────────────────────────────────────────────────
# AI-Stack-V1 — Environment Variables
# Copy this file to .env and fill in values for your environment.
# Never commit .env to source control.
# ─────────────────────────────────────────────────────────────────────────────

# ── API Server ────────────────────────────────────────────────────────────────

# TCP port the Express API server listens on.
# Required — the server will throw if this is not set.
# Used by: artifacts/api-server/src/index.ts
PORT=3001

# Pino log level (trace | debug | info | warn | error | fatal).
# Defaults to "info" if not set.
# Used by: artifacts/api-server/src/lib/logger.ts
LOG_LEVEL=info

# ── Frontend Dev Server ───────────────────────────────────────────────────────

# Target for the Vite /api proxy during local development.
# Defaults to http://localhost:3001 if not set.
# Used by: artifacts/localai-control-center/vite.config.ts
API_PROXY_TARGET=http://localhost:3001

# ── Distributed Node Authentication ──────────────────────────────────────────

# Shared secret token used by the distributed node auth middleware.
# Must be set in multi-node deployments. Single-node loopback is exempt.
# Used by: artifacts/api-server/src/lib/network-proxy.ts
# DISTRIBUTED_NODE_TOKEN=change-me-in-production

# ── Config Vault ──────────────────────────────────────────────────────────────

# Override the default vault directory (~/LocalAI-Tools/vault/).
# Leave unset to use the default.
# Used by: artifacts/api-server/src/lib/secure-config.ts
# LOCALAI_VAULT_DIR=

# ── Ollama ────────────────────────────────────────────────────────────────────

# Base URL for the local Ollama instance.
# Used by model-orchestrator, model-discovery, and chat routes.
# Defaults to http://127.0.0.1:11434 if not set.
# OLLAMA_BASE_URL=http://127.0.0.1:11434
